---
import Base from '../../layouts/Base.astro';
import PostGrid from '../../components/PostGrid.astro';
import SearchBox from '../../components/SearchBox.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Base title="博客归档" description="所有博客文章">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-12 sm:py-20">
    <h1 class="text-3xl sm:text-4xl font-bold text-[var(--color-text)] dark:text-[var(--color-text-dark)] text-center mb-8 sm:mb-12">
      博客归档
    </h1>

    <SearchBox />

    <PostGrid posts={posts} />
  </div>
</Base>
