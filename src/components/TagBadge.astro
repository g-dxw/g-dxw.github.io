---
export interface Props {
  tag: string;
}

const { tag } = Astro.props;
---

<a
  href={`/blog/tag/${tag}`}
  class="inline-block px-2.5 py-0.5 text-xs font-medium rounded-md bg-[var(--color-code-bg)] dark:bg-[var(--color-code-bg-dark)] text-[var(--color-accent)] dark:text-[var(--color-accent-dark)] hover:bg-[var(--color-accent)] hover:text-white dark:hover:bg-[var(--color-accent-dark)] transition-all no-underline"
>
  #{tag}
</a>
